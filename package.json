{
  "name": "portaldb",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "precommit:staged": "lint-staged",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm test -- --watch=false --coverage --coverage-reporters=text-summary && npm run build",
    "serve:ssr:portaldb": "node dist/portaldb/server/server.mjs",
    "prepare": "husky",
    "lint": "ng lint"
  },
  "lint-staged": {
    "*.{ts,html}": "eslint --fix",
    "*.{ts,js,mjs,cjs,json,css,html,md,yml,yaml}": "prettier --write"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.57.2",
    "vitest": "^4.0.8"
  },
  "type": "module"
}
